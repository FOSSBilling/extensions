---
import Base from '../../../layouts/Base.astro';
import { env } from 'cloudflare:workers';
import { requireUser } from '@/lib/auth-guard';
import { getUserProfile, updateUserProfile } from '@/lib/users';

const guard = await requireUser(Astro, env);
if (guard instanceof Response) return guard;
const user = guard;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const displayName = (
    (form.get('display_name') as string | null) ?? ''
  ).trim();
  const bio = ((form.get('bio') as string | null) ?? '').trim();

  await updateUserProfile(env.DB_EXTENSIONS, user.sub, {
    display_name: displayName || null,
    bio: bio || null,
  });
  return Astro.redirect('/account?profile_updated=1');
}

const profile = await getUserProfile(env.DB_EXTENSIONS, user.sub);
---

<Base title="Your profile — FOSSBilling Extensions">
  <div class="max-w-2xl mx-auto space-y-6">
    <h1 class="text-2xl font-semibold tracking-tight">Your profile</h1>
    <p class="text-muted-foreground text-sm">
      Your personal profile, separate from any developer/publisher identity. Not
      shown publicly yet — it's here for things like comments and ratings down
      the line.
    </p>

    <form method="POST" class="space-y-6">
      <div class="field">
        <label for="display_name">Display name</label>
        <input
          class="input"
          type="text"
          id="display_name"
          name="display_name"
          placeholder={user.name}
          value={profile.display_name ?? ''}
        />
        <p class="text-sm text-muted-foreground">
          Defaults to "{user.name}" from your sign-in provider if left blank.
        </p>
      </div>
      <div class="field">
        <label for="bio">Bio</label>
        <textarea
          class="textarea"
          id="bio"
          name="bio"
          rows="4"
          set:text={profile.bio ?? ''}
        />
      </div>

      <div class="flex justify-end gap-3">
        <a href="/account" class="btn" data-variant="ghost">Cancel</a>
        <button type="submit" class="btn">Save</button>
      </div>
    </form>
  </div>
</Base>
