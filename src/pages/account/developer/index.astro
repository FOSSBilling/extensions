---
import Base from '../../../layouts/Base.astro';
import { env } from 'cloudflare:workers';
import { requireUser } from '@/lib/auth-guard';
import { createApiClient, ApiRequestError } from '@/lib/apiClient';
import { getAuthorByOwner } from '@/lib/database';
import { buildAuthorProfile } from '@/lib/author-form';
import { AUTHOR_TYPES } from '@/types';

const guard = await requireUser(Astro, env);
if (guard instanceof Response) return guard;
const user = guard;

let author = await getAuthorByOwner(env.DB_EXTENSIONS, user.sub);
const isEdit = Boolean(author);

let error: string | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const payload = buildAuthorProfile(form, author);

  const api = createApiClient(env, user.sub);
  try {
    author = await api.upsertAuthorProfile(payload);
    return Astro.redirect('/account?profile_saved=1');
  } catch (e) {
    error =
      e instanceof ApiRequestError
        ? e.message
        : 'Something went wrong saving your developer profile. Please try again.';
  }
}
---

<Base title="Developer profile — FOSSBilling Extensions">
  <div class="max-w-2xl mx-auto space-y-6">
    <h1 class="text-2xl font-semibold tracking-tight">Developer profile</h1>
    <p class="text-muted-foreground text-sm">
      This is the publisher identity shown on your extensions in the directory,
      and on your public developer page. Changes take effect immediately — you
      can submit extensions under this profile right away. A moderator will
      review it separately and mark it approved, shown as a badge below.
    </p>

    {
      isEdit && (
        <div class="card flex items-center gap-4">
          {author!.avatar_url && (
            <img
              src={author!.avatar_url}
              alt=""
              class="w-14 h-14 rounded-full object-cover"
            />
          )}
          <div class="flex-1">
            <p class="font-medium flex items-center gap-2">
              {author!.name}
              {author!.approved ? (
                <span class="badge">Approved</span>
              ) : (
                <span class="badge-secondary">Not yet reviewed</span>
              )}
            </p>
            {author!.bio && (
              <p class="text-sm text-muted-foreground mt-1">{author!.bio}</p>
            )}
          </div>
          <a
            href={`/developer/${author!.id}`}
            class="btn"
            data-size="sm"
            data-variant="outline"
          >
            View public profile
          </a>
        </div>
      )
    }

    {
      error && (
        <div class="rounded-md border border-destructive/50 bg-destructive/10 px-4 py-3 text-sm text-destructive">
          {error}
        </div>
      )
    }

    <form method="POST" class="space-y-8">
      <fieldset class="fieldset space-y-4">
        <legend class="font-semibold mb-2">Publisher identity</legend>
        <div class="field">
          <label for="id">Publisher ID</label>
          <input
            class="input"
            type="text"
            id="id"
            name="id"
            required
            pattern="[a-z0-9]+(-[a-z0-9]+)*"
            placeholder="my-org"
            value={author?.id}
            readonly={isEdit}
          />
          {
            isEdit && (
              <p class="text-sm text-muted-foreground">
                The ID can't be changed after it's created.
              </p>
            )
          }
        </div>
        <div class="field">
          <label for="name">Publisher name</label>
          <input
            class="input"
            type="text"
            id="name"
            name="name"
            required
            value={author?.name}
          />
        </div>
        <div class="field">
          <label for="type">Publisher type</label>
          <select class="select" id="type" name="type">
            {
              AUTHOR_TYPES.map((t) => (
                <option value={t} selected={author?.type === t}>
                  {t}
                </option>
              ))
            }
          </select>
        </div>
        <div class="field">
          <label for="url">Publisher URL (optional)</label>
          <input
            class="input"
            type="url"
            id="url"
            name="url"
            value={author?.URL}
          />
        </div>
      </fieldset>

      <fieldset class="fieldset space-y-4">
        <legend class="font-semibold mb-2">Public profile</legend>
        <p class="text-sm text-muted-foreground -mt-2">
          Shown on your public developer page at
          {author ? ` /developer/${author.id}` : ' /developer/<your-id>'}.
        </p>
        <div class="field">
          <label for="avatar_url">Avatar/logo URL (optional)</label>
          <input
            class="input"
            type="url"
            id="avatar_url"
            name="avatar_url"
            value={author?.avatar_url}
          />
        </div>
        <div class="field">
          <label for="bio">Bio (optional)</label>
          <textarea
            class="textarea"
            id="bio"
            name="bio"
            rows="4"
            maxlength="500"
            set:text={author?.bio ?? ''}
          />
          <p class="text-sm text-muted-foreground">Up to 500 characters.</p>
        </div>
      </fieldset>

      <fieldset class="fieldset space-y-4">
        <legend class="font-semibold mb-2">Private contact</legend>
        <div class="field">
          <label for="contact_email">Contact email (optional)</label>
          <input
            class="input"
            type="email"
            id="contact_email"
            name="contact_email"
            value={author?.contact_email}
          />
          <p class="text-sm text-muted-foreground">
            Never shown publicly — only visible to FOSSBilling moderators, in
            case they need to reach you about this profile or its extensions.
          </p>
        </div>
      </fieldset>

      <div class="flex justify-end gap-3">
        <a href="/account" class="btn" data-variant="ghost">Cancel</a>
        <button type="submit" class="btn">
          {isEdit ? 'Save changes' : 'Create developer profile'}
        </button>
      </div>
    </form>
  </div>
</Base>
