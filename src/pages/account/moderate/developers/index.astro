---
import Base from '../../../../layouts/Base.astro';
import { env } from 'cloudflare:workers';
import { requireModerator } from '@/lib/auth-guard';
import { createApiClient } from '@/lib/apiClient';
import type { AuthorProfile } from '@/types';

const guard = await requireModerator(Astro, env);
if (guard instanceof Response) return guard;
const user = guard;

const api = createApiClient(env, user.sub);
let authors: AuthorProfile[] = [];
let loadError = false;
try {
  authors = await api.listUnapprovedAuthors();
} catch {
  loadError = true;
}
---

<Base title="Developer profiles — FOSSBilling Extensions">
  <div class="max-w-3xl mx-auto space-y-6">
    <div class="flex items-center justify-between gap-4">
      <h1 class="text-2xl font-semibold tracking-tight">
        Developer profiles awaiting review
      </h1>
      <a href="/account/moderate" class="btn" data-variant="outline">
        Extension queue
      </a>
    </div>

    {
      Astro.url.searchParams.get('error') && (
        <div class="rounded-md border border-destructive/50 bg-destructive/10 px-4 py-3 text-sm text-destructive">
          {Astro.url.searchParams.get('error')}
        </div>
      )
    }

    <p class="text-sm text-muted-foreground">
      These profiles are already live — approval is a trust badge, not a publish
      gate. An edit to an approved profile clears its badge again until it's
      reviewed here.
    </p>

    {
      loadError ? (
        <p class="text-sm text-destructive">
          Unable to load developer profiles right now.
        </p>
      ) : authors.length === 0 ? (
        <p class="text-muted-foreground text-sm">
          No developer profiles awaiting review.
        </p>
      ) : (
        <ul class="space-y-4">
          {authors.map((a) => (
            <li class="card">
              <header class="flex items-start justify-between gap-4">
                <div>
                  <h2 class="font-semibold">
                    {a.name} ({a.id})
                  </h2>
                  <p class="text-sm text-muted-foreground">
                    {a.type}
                    {a.URL && (
                      <>
                        {' '}
                        &middot; <a href={a.URL}>{a.URL}</a>
                      </>
                    )}
                  </p>
                </div>
                <form
                  method="POST"
                  action={`/account/moderate/developers/${a.id}/approve`}
                >
                  <button type="submit" class="btn" data-size="sm">
                    Approve
                  </button>
                </form>
              </header>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</Base>
