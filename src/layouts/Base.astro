---
import '@/styles/global.css';
import LogoLight from '@/assets/logo-light.svg';
import LogoDark from '@/assets/logo-dark.svg';
import Container from '@/components/Container.astro';
import { Sun, Moon } from '@lucide/astro';
import { env } from 'cloudflare:workers';
import { getSessionUser } from '@/lib/session';

interface Props {
  title: string;
}

const { title } = Astro.props;
const user = await getSessionUser(Astro.cookies, env.SESSION_SECRET);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem('themeMode');
          if (
            stored
              ? stored === 'dark'
              : matchMedia('(prefers-color-scheme: dark)').matches
          ) {
            document.documentElement.classList.add('dark');
          }
        } catch (_) {}

        const apply = (dark) => {
          document.documentElement.classList.toggle('dark', dark);
          try {
            localStorage.setItem('themeMode', dark ? 'dark' : 'light');
          } catch (_) {}
        };

        document.addEventListener('basecoat:theme', (event) => {
          const mode = event.detail?.mode;
          apply(
            mode === 'dark'
              ? true
              : mode === 'light'
                ? false
                : !document.documentElement.classList.contains('dark'),
          );
        });
      })();
    </script>
    <script>
      import 'basecoat-css/basecoat';
      import 'basecoat-css/tabs';
    </script>
    <title>{title}</title>
  </head>
  <body class="bg-background">
    <header
      class="border-b border-border sticky top-0 z-50 bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60"
    >
      <Container class="flex h-18 items-center justify-between">
        <div class="flex items-center">
          <a href="/" aria-label="FOSSBilling Extensions Home">
            <LogoLight class="h-8 w-auto dark:hidden" />
            <LogoDark class="h-8 w-auto hidden dark:block" />
          </a>
          <span
            class="ml-3 pl-3 border-s text-sm font-semibold uppercase tracking-wider"
            >Extensions</span
          >
          <span class="ml-2 badge-secondary">beta</span>
        </div>
        <div class="flex items-center gap-3">
          {
            user ? (
              <div class="flex items-center gap-2">
                {user.picture && (
                  <img
                    src={user.picture}
                    alt=""
                    referrerpolicy="no-referrer"
                    class="size-6 rounded-full"
                  />
                )}
                <span class="text-sm text-muted-foreground hidden sm:inline">
                  {user.name}
                </span>
                <form method="POST" action="/auth/logout">
                  <button type="submit" class="btn-sm-outline">
                    Sign out
                  </button>
                </form>
              </div>
            ) : (
              <a href="/auth/login" class="btn-sm-outline">
                Sign in with GitHub
              </a>
            )
          }
          <button
            type="button"
            aria-label="Toggle Dark Mode"
            data-tooltip="Toggle Dark Mode"
            data-side="bottom"
            data-align="end"
            onclick="document.dispatchEvent(new CustomEvent('basecoat:theme'))"
            class="btn-icon-outline size-8"
          >
            <Sun class="w-5 h-5 hidden dark:block" aria-hidden="true" />
            <Moon class="w-5 h-5 block dark:hidden" aria-hidden="true" />
          </button>
        </div>
      </Container>
    </header>
    <main>
      <Container class="py-6 sm:py-10">
        {
          Astro.url.searchParams.get('auth_error') && (
            <div class="mb-6 rounded-md border border-destructive/50 bg-destructive/10 px-4 py-3 text-sm text-destructive">
              Sign-in with GitHub failed. Please try again.
            </div>
          )
        }
        <slot />
      </Container>
    </main>
    <footer class="border-t border-border py-8">
      <Container class="text-center text-sm text-muted-foreground">
        <p>&copy; 2026 &mdash; The FOSSBilling project.</p>
      </Container>
    </footer>
  </body>
</html>
